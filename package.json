{
  "name": "iranse-app",
  "version": "1.0.0",
  "packageManager": "npm@11.1.0",
  "private": true,
  "description": "AI-powered job matching platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "turbo run db:migrate",
    "api:dev": "npm run dev --workspace=apps/api",
    "worker:dev": "npm run worker:dev --workspace=apps/api",
    "web:dev": "npm run dev --workspace=apps/web",
    "admin:dev": "npm run dev --workspace=apps/admin"
  },
  "devDependencies": {
    "turbo": "^2.0.6",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fayeloja/iranse-app.git"
  },
  "keywords": [],
  "author": "Fatai Ayeloja",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/fayeloja/iranse-app/issues"
  },
  "homepage": "https://github.com/fayeloja/iranse-app#readme"
}
