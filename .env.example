PORT=3000
NODE_ENV=development

# Postgres & Redis Connection URLs
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iranse_dev?sslmode=disable
REDIS_URL=redis://localhost:6379

# Cryptography & Sessions
JWT_ACCESS_SECRET=super_secret_jwt_access_key_minimum_16_chars
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_minimum_16_chars

# 32-byte hexadecimal key for AES-256-GCM credentials encryption (64 hex characters)
ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# Third-Party Integrations
TERMII_API_KEY=
TERMII_SENDER_ID=Iransé
PAYSTACK_SECRET_KEY=
KYC_VENDOR_API_KEY=

# Worker queues selection (comma-separated list, or "all")
WORKER_QUEUES=all
